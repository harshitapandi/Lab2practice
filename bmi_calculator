def calculate_bmi(height,weight):
    print(f"Height = {height}")
    print(f"Weight = {weight}")
    bmi = (weight) / ((height) ** 2)
    print(f"BMI = {bmi}")

    if bmi < 18.5:
        print("Underweight")
    elif bmi >= 18.5 and bmi < 25:
        print("Normal weight")
    else:
        print("Overweight")

calculate_bmi(weight=57, height=1.73)




